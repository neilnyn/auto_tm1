{
  "enabledPlugins": {
    "agent-skills@addy-agent-skills": false
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".venv/Scripts/python.exe hooks/cc_workon.py"
          }
        ]
      },
      {
        "matcher": "mcp__tm1__*",
        "hooks": [
          {
            "type": "command",
            "command": ".venv/Scripts/python.exe hooks/spec_gate.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".venv/Scripts/python.exe hooks/session_cleanup.py"
          }
        ]
      }
    ]
  }
}
