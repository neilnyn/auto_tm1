  "_spec_to_mcp_mapping": {
    "_comment": "Each top-level field maps to specific MCP tool calls. Follow the execution order below.",
    "execution_order": [
      "1. dimension_name + elements + edges + hierarchy -> create_dimension()",
      "2. attributes[] -> create_element_attribute() for each attribute",
      "3. attribute_values[] -> write_element_attributes() (batch)",
      "4. subsets[] -> create_subset() for each (static: elements, dynamic: expression)"
    ],
    "field_descriptions": {
      "dimension_name": "Passed to create_dimension as dimension_name",
      "hierarchy_name": "Passed to create_dimension as hierarchy. null = use dimension_name.",
      "elements": "Passed to create_dimension as elements array [{name, type}]",
      "edges": "Passed to create_dimension as edges array [{parent, child, weight}]",
      "attributes": "Each item -> create_element_attribute(dimension_name, attribute_name, attribute_type)",
      "attribute_values": "Entire array -> write_element_attributes(dimension_name, attribute_values)",
      "subsets": "Each item -> create_subset. If type=static: pass elements. If type=dynamic: pass expression."
    }
  },
