  "attributes": [
    {"name": "Category", "type": "String"},
    {"name": "Product Code", "type": "Alias"}
  ],
  "attribute_values": [
    {"element": "Laptop", "attribute": "Category", "value": "Electronics"},
    {"element": "Laptop", "attribute": "Product Code", "value": "E001"},
    {"element": "Phone", "attribute": "Category", "value": "Electronics"},
    {"element": "Phone", "attribute": "Product Code", "value": "E002"},
    {"element": "Tablet", "attribute": "Category", "value": "Electronics"},
    {"element": "Tablet", "attribute": "Product Code", "value": "E003"},
    {"element": "TV", "attribute": "Category", "value": "Electronics"},
    {"element": "TV", "attribute": "Product Code", "value": "E004"},
    {"element": "T-Shirt", "attribute": "Category", "value": "Clothing"},
    {"element": "T-Shirt", "attribute": "Product Code", "value": "C001"},
    {"element": "Jeans", "attribute": "Category", "value": "Clothing"},
