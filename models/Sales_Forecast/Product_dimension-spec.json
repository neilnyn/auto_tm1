    {"parent": "Total Product", "child": "Clothing", "weight": 1.0},
    {"parent": "Electronics", "child": "Laptop", "weight": 1.0},
    {"parent": "Electronics", "child": "Phone", "weight": 1.0},
    {"parent": "Electronics", "child": "Tablet", "weight": 1.0},
