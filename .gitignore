# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/

# Virtual environment
.venv/

# Config (contains credentials)
config/tm1py_config.ini

# IDE
.idea/
*.iml

# pytest
.pytest_cache/

# Claude Code local settings
.claude/settings.json
.claude/settings.local.json

# Docs (local working documents)
docs/

# Agent memory (private, per-user)
.claude/agent-memory/

# APQ Logging model specs (instance-specific)
models/APQ_Logging/

# Delivery artifacts — tracked for initial sync only, local changes ignored
# (use --assume-unchanged on existing tracked files)
models/**/*
!models/.gitkeep
processes/**/*
!processes/.gitkeep

# OS
Thumbs.db
.DS_Store

# uv lock (optional — uncomment if you don't want to track it)
# uv.lock
